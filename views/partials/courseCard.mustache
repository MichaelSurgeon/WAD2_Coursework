<article class="card">
  <div class="card-header">
    <h2><a href="/courses/{{id}}">{{title}}</a></h2>
    <span class="badge badge-muted">{{level}}</span>
    {{#allowDropIn}}<span class="badge badge-primary">Drop-in Available</span>{{/allowDropIn}}
    {{^allowDropIn}}<span class="badge badge-warning">Full Course Only</span>{{/allowDropIn}}
  </div>

  <div class="card-section">
    <div class="grid-2-cols">
      <div class="info-box">
        <div class="info-label">📍 Location</div>
        <div class="info-value">{{location}}</div>
      </div>
      <div class="info-box">
        <div class="info-label">💷 Pricing</div>
        <div class="info-value">{{priceDisplay}}</div>
      </div>
    </div>
  </div>

  <div class="card-section">
    <p class="card-description">{{description}}</p>
  </div>

  <div class="card-section">
    <div class="session-meta">
      <div class="meta-item">
        <span class="meta-label">Type</span>
        <span class="badge badge-neutral">{{type}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Duration</span>
        <span class="badge badge-neutral">{{durationDisplay}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Sessions</span>
        <span class="badge badge-neutral">{{sessionsCount}} sessions</span>
      </div>
    </div>
  </div>

  <div class="card-action">
    <a href="/courses/{{id}}" class="btn btn-info">View Details</a>
  </div>
</article>
