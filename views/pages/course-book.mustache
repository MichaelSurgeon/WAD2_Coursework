{{> head}}
{{> header}}

<main class="wrap">
  <div class="card card-medium">
    <div class="card-header">
      <h1>Book: {{course.title}}</h1>
      <p class="page-header-subtitle">
        Level: <strong>{{course.level}}</strong> • Type: <strong>{{course.type}}</strong> {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
      </p>
    </div>

    {{> errorAlert}}

    <div class="card-section">
      <h3>Course Information</h3>
      <p class="course-info-description">{{course.description}}</p>
      <p class="course-info-dates">📅 {{course.startDate}} – {{course.endDate}}</p>
    </div>

    <form method="post" action="/courses/{{course._id}}/book">
      <input type="hidden" name="userId" value="{{user._id}}">

      {{> bookingUserForm}}

      <div class="card-section">
        <h3>Booking Summary</h3>
        <p class="booking-summary-text">This booking reserves your seat across <strong>{{sessionsCount}}</strong> sessions:</p>
        <ul class="booking-summary-list">
          {{#sessions}}
          <li>{{start}} <span class="booking-summary-remaining">({{remaining}} places left)</span></li>
          {{/sessions}}
        </ul>
      </div>

      <div class="card-action">
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Confirm Booking</button>
          <a href="/courses/{{course._id}}" class="btn btn-secondary">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</main>

{{> footer}}
