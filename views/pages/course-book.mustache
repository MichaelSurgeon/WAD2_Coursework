{{> head}}
{{> header}}

<main class="wrap">
  <div class="card" style="max-width: 700px; margin: 2rem auto;">
    <div class="card-header">
      <h1>Book: {{course.title}}</h1>
      <p class="page-header-subtitle">
        Level: <strong>{{course.level}}</strong> • Type: <strong>{{course.type}}</strong> {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
      </p>
    </div>

    {{> errorAlert}}

    <div class="card-section">
      <h3>Course Information</h3>
      <p style="color: #666; margin: 0;">{{course.description}}</p>
      <p style="color: #999; font-size: 0.9rem; margin: 1rem 0 0 0;">📅 {{course.startDate}} – {{course.endDate}}</p>
    </div>

    <form method="post" action="/courses/{{course.id}}/book">
      <input type="hidden" name="userId" value="{{user._id}}">

      {{> bookingUserForm}}

      <div class="card-section">
        <h3>Booking Summary</h3>
        <p style="color: #666; margin: 0;">This booking reserves your seat across <strong>{{sessionsCount}}</strong> sessions:</p>
        <ul style="margin: 1rem 0 0 0; color: #666; padding-left: 1.5rem;">
          {{#sessions}}
          <li style="margin: 0.5rem 0;">{{start}} <span style="color: #999;">({{remaining}} places left)</span></li>
          {{/sessions}}
        </ul>
      </div>

      <div class="card-action">
        <div class="form-actions">
          <button class="btn btn-primary" type="submit">Confirm Booking</button>
          <a href="/courses/{{course.id}}" class="btn btn-secondary">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</main>

{{> footer}}
