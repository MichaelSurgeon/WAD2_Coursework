{{> head}}
{{> header}}

<main class="wrap">
  <div class="page-container">
    <div class="card m-bottom-2">
      <div class="card-header">
        <h1 class="m-0">{{course.title}}</h1>
        <p class="page-header-subtitle">
          Level: <strong>{{course.level}}</strong> • Type: <strong>{{course.type}}</strong> {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
        </p>
      </div>

      <div class="card-section">
        <p style="color: #666; margin: 0; line-height: 1.6;">{{course.description}}</p>
      </div>

      <div class="card-section">
        <div class="info-section">
          {{#course.location}}
          <div class="info-box">
            <strong>📍 Location</strong>
            <p class="m-top-0-5" style="color: #666;">{{course.location}}</p>
          </div>
          {{/course.location}}
          {{#course.priceDisplay}}
          <div class="info-box">
            <strong>💷 Pricing</strong>
            <p class="m-top-0-5" style="color: #666;">{{course.priceDisplay}}</p>
          </div>
          {{/course.priceDisplay}}
          {{#course.startDate}}
          <div class="info-box">
            <strong>📅 Duration</strong>
            <p class="m-top-0-5" style="color: #666;">{{course.startDate}} – {{course.endDate}}</p>
          </div>
          {{/course.startDate}}
          {{#course.sessionsCount}}
          <div class="info-box">
            <strong>🧘 Sessions</strong>
            <p class="m-top-0-5" style="color: #666;">{{course.sessionsCount}} total sessions</p>
          </div>
          {{/course.sessionsCount}}
        </div>
      </div>

      {{#user}}
      <div class="card-action">
        <form action="/courses/{{course.id}}/book" method="post" style="width: 100%;">
          <input type="hidden" name="userId" value="{{user._id}}">
          <button class="btn btn-primary btn-full-width" type="submit">Book This Course</button>
        </form>
      </div>
      {{/user}}
      {{^user}}
      <div class="card-section section-info-blue">
        <p class="m-0">To book this course, please <a href="/login">log in</a> or <a href="/register">register</a>.</p>
      </div>
      {{/user}}
    </div>

    <div class="card">
      <div class="card-header">
        <h2 style="margin: 0;">Class Schedule</h2>
        <p style="margin: 0.5rem 0 0 0; color: #666; font-size: 0.9rem;">All available sessions for this course</p>
      </div>

      <div class="card-section" style="overflow-x: auto;">
        <table class="table">
          <thead>
            <tr>
              <th>Start Time</th>
              <th>End Time</th>
              <th class="text-center">Capacity</th>
              <th class="text-center">Booked</th>
              <th class="text-center">Available</th>
              <th class="text-center">Action</th>
            </tr>
          </thead>
          <tbody>
            {{#sessions}}
            <tr>
              <td><time datetime="{{startIso}}">{{start}}</time></td>
              <td><time datetime="{{endIso}}">{{end}}</time></td>
              <td class="text-center">{{capacity}}</td>
              <td class="text-center">{{booked}}</td>
              <td class="text-center">{{remaining}}</td>
              <td class="text-center">
                {{#course.allowDropIn}}
                  <form action="/sessions/{{_id}}/book" method="post">
                    {{#user}}
                    <button class="btn btn-primary" type="submit" {{#isFull}}disabled aria-disabled="true"{{/isFull}}>{{#isFull}}Full{{/isFull}}{{^isFull}}Book{{/isFull}}</button>
                    {{/user}}
                    {{^user}}
                    <span class="muted">Log in to book</span>
                    {{/user}}
                  </form>
                {{/course.allowDropIn}}
                {{^course.allowDropIn}}
                  <span class="muted">Drop-ins disabled</span>
                {{/course.allowDropIn}}
              </td>
            </tr>
            {{/sessions}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>

{{> footer}}
