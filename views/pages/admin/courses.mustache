{{> head}}
{{> header}}

<main class="wrap">
  <div class="page-container">
    <div class="card page-header">
      <div class="card-header">
        <h1 class="page-header-title">Manage Courses</h1>
        <p class="page-header-subtitle">Add, edit, or delete courses from your studio</p>
      </div>

      <div class="card-action">
        <a href="/admin/courses/new" class="btn btn-primary">➕ Add New Course</a>
      </div>
    </div>

    <div class="courses-grid">
      {{#courses}}
      <div class="card">
        <div class="card-section">
          <div class="course-card-header">
            <div>
              <h3 class="course-card-title">{{title}}</h3>
              <div class="course-card-meta">
                <span><strong>Level:</strong> {{level}}</span>
                <span><strong>Type:</strong> {{type}}</span>
              </div>
            </div>
            <div class="course-card-sessions">
              <p class="m-0">{{sessionsCount}} sessions</p>
            </div>
          </div>

          <div class="course-card-info card-section-padding">
            <div class="info-box">
              <strong>Duration</strong>
              <p class="m-0 text-muted-small">{{startDate}} – {{endDate}}</p>
            </div>
            <div class="info-box">
              <strong>Sessions</strong>
              <p class="m-0 text-muted-small">{{sessionsCount}} sessions total</p>
            </div>
          </div>
        </div>

        <div class="card-action">
          <div class="button-container-full-flex">
            <a href="/admin/courses/{{_id}}/edit" class="btn btn-primary">Edit Course</a>
            <a href="/admin/courses/{{_id}}/sessions" class="btn btn-info">Manage Sessions</a>
            <a href="/admin/courses/{{_id}}/class-list" class="btn btn-info">Class List</a>
            <form method="post" action="/admin/courses/{{_id}}/delete">
              <button class="btn btn-delete" type="submit" onclick="return confirm('Are you sure you want to delete this course?')">Delete</button>
            </form>
          </div>
        </div>
      </div>
      {{/courses}}
    </div>

    {{#pagination}}
    <div class="pagination-controls">
      {{#hasPrev}}<a href="{{prevLink}}" class="btn btn-secondary">← Previous</a>{{/hasPrev}}
      <span class="pagination-info">Showing {{startItem}}–{{endItem}} of {{total}} | Page {{page}} of {{totalPages}}</span>
      {{#hasNext}}<a href="{{nextLink}}" class="btn btn-secondary">Next →</a>{{/hasNext}}
    </div>
    {{/pagination}}

    {{^courses}}
    <div class="card text-center">
      <div class="card-section">
        <p class="empty-state-message">No courses yet.</p>
        <a href="/admin/courses/new" class="btn btn-primary">Create Your First Course</a>
      </div>
    </div>
    {{/courses}}

    <div class="back-link">
      <a href="/admin">← Back to Dashboard</a>
    </div>
  </div>
</main>

{{> footer}}
