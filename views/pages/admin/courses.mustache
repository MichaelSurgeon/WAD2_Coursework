{{> head}}
{{> header}}

<main class="wrap">
  <div style="max-width: 900px; margin: 2rem auto;">
    <div class="card" style="margin-bottom: 2rem;">
      <div class="card-header">
        <h1 style="margin: 0;">Manage Courses</h1>
        <p style="margin: 0.5rem 0 0 0; color: #666; font-size: 0.95rem;">Add, edit, or delete courses from your studio</p>
      </div>

      <div class="card-action">
        <a href="/admin/courses/new" class="btn btn-primary" style="display: inline-block; padding: 0.7rem 2rem;">➕ Add New Course</a>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">
      {{#courses}}
      <div class="card">
        <div class="card-section">
          <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
            <div>
              <h3 style="margin: 0 0 0.5rem 0;">{{title}}</h3>
              <div style="display: flex; gap: 1rem; color: #666; font-size: 0.9rem;">
                <span><strong>Level:</strong> {{level}}</span>
                <span><strong>Type:</strong> {{type}}</span>
              </div>
            </div>
            <div style="text-align: right;">
              <p style="margin: 0; color: #999; font-size: 0.85rem;">{{sessionsCount}} sessions</p>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; padding-top: 1rem; border-top: 1px solid #eee;">
            <div class="info-box">
              <strong>Duration</strong>
              <p style="margin: 0.5rem 0 0 0; color: #666; font-size: 0.9rem;">{{startDate}} – {{endDate}}</p>
            </div>
            <div class="info-box">
              <strong>Sessions</strong>
              <p style="margin: 0.5rem 0 0 0; color: #666; font-size: 0.9rem;">{{sessionsCount}} sessions total</p>
            </div>
          </div>
        </div>

        <div class="card-action">
          <div style="display: flex; gap: 0.8rem; justify-content: center;">
            <a href="/admin/courses/{{id}}/edit" class="btn" style="flex: 1; padding: 0.6rem 1rem; background-color: var(--brand); color: white; text-decoration: none; border: none; border-radius: 4px; text-align: center; cursor: pointer;">Edit</a>
            <form method="post" action="/admin/courses/{{id}}/delete" style="flex: 1;">
              <button class="btn" type="submit" onclick="return confirm('Are you sure you want to delete this course?')" style="width: 100%; padding: 0.6rem 1rem; background-color: #f44; color: white; border: none; border-radius: 4px; cursor: pointer;">Delete</button>
            </form>
          </div>
        </div>
      </div>
      {{/courses}}
    </div>

    {{^courses}}
    <div class="card" style="text-align: center;">
      <div class="card-section">
        <p style="color: #666; font-size: 1.05rem; margin: 2rem 0;">No courses yet.</p>
        <a href="/admin/courses/new" class="btn btn-primary" style="display: inline-block; padding: 0.7rem 2rem;">Create Your First Course</a>
      </div>
    </div>
    {{/courses}}

    <div style="margin-top: 2rem;">
      <a href="/admin" style="color: var(--brand); text-decoration: none;">← Back to Dashboard</a>
    </div>
  </div>
</main>

{{> footer}}
