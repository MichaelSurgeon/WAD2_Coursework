{{> head}}
{{> header}}

<main class="wrap">
  <div class="card container">
    <div class="card-header">
      <h1>Add Sessions: {{course.title}}</h1>
      <p>{{course.startDate}} – {{course.endDate}}</p>
    </div>

    {{> errorAlert}}

    {{^sessionsList}}
    <div class="card-section card-section-info">
      <strong>Add at least one session before completing course creation</strong>
      <p>Each course requires at least one session (class/meeting time) for students to book.</p>
    </div>
    {{/sessionsList}}

    <form method="post" action="/admin/courses/{{course._id}}/sessions{{#isEditSession}}/{{editingSessionId}}/edit{{/isEditSession}}">
      <div class="card-section form-section">
        <h3>{{#isEditSession}}Edit Session{{/isEditSession}}{{^isEditSession}}Add New Session{{/isEditSession}}</h3>

        <div class="admin-form-grid">
          <div class="field">
            <label for="startDateTime" class="form-field-label">Start Date & Time <span>*</span></label>
            <input id="startDateTime" name="startDateTime" type="datetime-local" required class="form-field-input" value="{{sessionForm.startDateTime}}">
          </div>

          <div class="field">
            <label for="endDateTime" class="form-field-label">End Date & Time <span>*</span></label>
            <input id="endDateTime" name="endDateTime" type="datetime-local" required class="form-field-input" value="{{sessionForm.endDateTime}}">
          </div>

          <div class="field">
            <label for="capacity" class="form-field-label">Capacity <span>*</span></label>
            <input id="capacity" name="capacity" type="number" min="1" required class="form-field-input" value="{{sessionForm.capacity}}">
          </div>

          <div class="field">
            <label for="location" class="form-field-label">Location <span>*</span></label>
            <input id="location" name="location" type="text" required class="form-field-input" value="{{sessionForm.location}}">
          </div>

          <div class="field">
            <label for="price" class="form-field-label">Price (£) <span>*</span></label>
            <input id="price" name="price" type="number" step="0.01" min="0" required class="form-field-input" value="{{sessionForm.price}}">
          </div>

          <div class="field">
            <label for="description" class="form-field-label">Description <span>*</span></label>
            <input id="description" name="description" type="text" required class="form-field-input" value="{{sessionForm.description}}">
          </div>
        </div>
      </div>

      <div class="card-action">
        <div class="admin-btn-group">
          <button class="btn btn-primary" type="submit">{{#isEditSession}}Update Session{{/isEditSession}}{{^isEditSession}}Add Session{{/isEditSession}}</button>
          {{#isEditSession}}
          <a href="/admin/courses/{{course._id}}/sessions" class="btn btn-secondary">Cancel</a>
          {{/isEditSession}}
        </div>
      </div>
    </form>

    {{#sessionsList}}
    <div class="card-section">
      <h3 class="session-count-title">Sessions Added ({{count}})</h3>
      <div class="session-count-info">
        <p>You can see added sessions below</p>
        <p class="warning">Deleting the last session will remove the entire course.</p>
      </div>
      
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Date & Time</th>
              <th class="text-center">Capacity</th>
              <th class="text-center">Location</th>
              <th class="text-center">Description</th>
              <th class="text-center">Price</th>
              <th class="text-center">Action</th>
            </tr>
          </thead>
          <tbody>
            {{#items}}
            <tr>
              <td>{{start}}</td>
              <td class="text-center">{{capacity}}</td>
              <td class="text-center">{{location}}</td>
              <td class="text-center">{{description}}</td>
              <td class="text-center">{{priceDisplay}}</td>
              <td class="text-center">
                <a href="/admin/courses/{{courseId}}/sessions/{{_id}}/edit" class="btn btn-secondary">Edit</a>
                <form method="post" action="/admin/courses/{{courseId}}/sessions/{{_id}}/delete" class="delete-form">
                  <button class="btn btn-delete" type="submit">Delete</button>
                </form>
              </td>
            </tr>
            {{/items}}
          </tbody>
        </table>
      </div>

      <div class="card-action">
        <div class="button-container-full-flex">
          <a href="/admin/courses" class="btn btn-primary">All Done</a>
          <a href="/admin/courses/{{course._id}}/edit" class="btn btn-secondary">Edit Course</a>
        </div>
      </div>
    </div>
    {{/sessionsList}}
  </div>
</main>

{{> footer}}
