{{> head}}
{{> header}}

<main class="wrap">
  <div class="page-container container-lg">
    <div class="card page-header">
      <div class="card-header">
        <h1 class="page-header-title">Admin Dashboard</h1>
        <p class="page-header-subtitle">Welcome, <strong>{{user.username}}</strong>. Manage your yoga studio from here.</p>
      </div>
    </div>

    <div class="stat-card-grid">
      <div class="card">
        <div class="card-section stat-card-content">
          <p class="stat-card-label">Active Courses</p>
          <h2 class="stat-card-number">{{coursesCount}}</h2>
        </div>
        <div class="card-action">
          <a href="/admin/courses" class="btn btn-primary btn-block text-center">Manage Courses</a>
        </div>
      </div>

      <div class="card">
        <div class="card-section stat-card-content">
          <p class="stat-card-label">Registered Users</p>
          <h2 class="stat-card-number">{{usersCount}}</h2>
        </div>
        <div class="card-action">
          <a href="/admin/users" class="btn btn-primary btn-block text-center">Manage Users</a>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h2 class="m-0">Quick Actions</h2>
      </div>

      <div class="card-section">
        <div class="flex-column">
          <a href="/admin/courses/new" class="btn btn-primary btn-block text-center">➕ Add New Course</a>
          <a href="/admin/courses" class="btn btn-secondary btn-block text-center">View All Courses</a>
          <a href="/admin/users" class="btn btn-secondary btn-block text-center">Manage Users</a>
        </div>
      </div>
    </div>
  </div>
</main>

{{> footer}}
