{{> head}}
{{> header}}

<main class="wrap">
  <div style="max-width: 900px; margin: 2rem auto;">
    <div class="card" style="margin-bottom: 2rem;">
      <div class="card-header">
        <h1 style="margin: 0;">Manage Users</h1>
        <p style="margin: 0.5rem 0 0 0; color: #666; font-size: 0.95rem;">View all users and manage their roles</p>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">
      {{#users}}
      <div class="card">
        <div class="card-section">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <h3 style="margin: 0;">{{username}}</h3>
              <p style="margin: 0.5rem 0 0 0; color: #666; font-size: 0.9rem;">{{email}}</p>
            </div>
            <div>
              {{#isOrganiser}}
              <span style="display: inline-block; background-color: var(--brand); color: white; padding: 0.3rem 0.8rem; border-radius: 3px; font-size: 0.85rem; font-weight: 600;">Organiser</span>
              {{/isOrganiser}}
              {{^isOrganiser}}
              <span style="display: inline-block; background-color: #e0e0e0; color: #666; padding: 0.3rem 0.8rem; border-radius: 3px; font-size: 0.85rem;">User</span>
              {{/isOrganiser}}
            </div>
          </div>
        </div>

        <div class="card-action">
          <div style="display: flex; gap: 0.8rem; justify-content: center;">
            {{^isOrganiser}}
            <form method="post" action="/admin/users/{{id}}/promote" style="flex: 1;">
              <button class="btn" type="submit" style="width: 100%; padding: 0.6rem 1rem; background-color: var(--brand); color: white; border: none; border-radius: 4px; cursor: pointer;">Promote to Organiser</button>
            </form>
            {{/isOrganiser}}
            {{#isOrganiser}}
            <div style="flex: 1; padding: 0.6rem 1rem; text-align: center; color: #999; font-size: 0.9rem;">Organiser</div>
            {{/isOrganiser}}
            <form method="post" action="/admin/users/{{id}}/delete" style="flex: 1;">
              <button class="btn" type="submit" onclick="return confirm('Are you sure you want to delete this user?')" style="width: 100%; padding: 0.6rem 1rem; background-color: #f44; color: white; border: none; border-radius: 4px; cursor: pointer;">Delete</button>
            </form>
          </div>
        </div>
      </div>
      {{/users}}
    </div>

    {{^users}}
    <div class="card" style="text-align: center;">
      <div class="card-section">
        <p style="color: #666; font-size: 1.05rem; margin: 2rem 0;">No users found.</p>
      </div>
    </div>
    {{/users}}

    <div style="margin-top: 2rem;">
      <a href="/admin" style="color: var(--brand); text-decoration: none;">← Back to Dashboard</a>
    </div>
  </div>
</main>

{{> footer}}
