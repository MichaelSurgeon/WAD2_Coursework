{{> head}}
{{> header}}

<main class="wrap">
  <div class="page-container">
    <div class="card page-header">
      <div class="card-header">
        <h1 class="page-header-title">Manage Users</h1>
        <p class="page-header-subtitle">View all users and manage their roles</p>
      </div>

      <div class="card-action">
        <a href="/admin/users/new" class="btn btn-primary">➕ Add New User</a>
      </div>
    </div>

    <div class="user-list">
      {{#users}}
      <div class="card">
        <div class="card-section">
          <div class="user-card-header">
            <div class="user-info">
              <h3>{{username}}</h3>
              <p>{{email}}</p>
            </div>
            <div>
              {{#isOrganiser}}
              <span class="user-role-badge user-role-badge-organiser">Organiser</span>
              {{/isOrganiser}}
              {{^isOrganiser}}
              <span class="user-role-badge user-role-badge-user">User</span>
              {{/isOrganiser}}
            </div>
          </div>
        </div>

        <div class="card-action">
          <div class="button-container-full-flex">
            {{^isOrganiser}}
            <form method="post" action="/admin/users/{{id}}/promote">
              <button class="btn btn-primary" type="submit">Promote to Organiser</button>
            </form>
            {{/isOrganiser}}
            {{#isOrganiser}}
            {{^isCurrentUser}}
            <form method="post" action="/admin/users/{{id}}/demote">
              <button class="btn btn-secondary" type="submit">Demote to User</button>
            </form>
            {{/isCurrentUser}}
            {{/isOrganiser}}
            {{^isCurrentUser}}
            <form method="post" action="/admin/users/{{id}}/delete">
              <button class="btn btn-delete" type="submit" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
            </form>
            {{/isCurrentUser}}
          </div>
        </div>
      </div>
      {{/users}}
    </div>

    {{^users}}
    <div class="card text-center">
      <div class="card-section">
        <p class="text-muted empty-state-message">No users found.</p>
        <a href="/admin/users/new" class="btn btn-primary">Create Your First User</a>
      </div>
    </div>
    {{/users}}

    <div class="back-link">
      <a href="/admin">← Back to Dashboard</a>
    </div>
  </div>
</main>

{{> footer}}
