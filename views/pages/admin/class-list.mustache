{{>head}}
{{>header}}

<main class="wrap">
  <div class="card container">
    <div class="card-header">
      <h1>{{title}}</h1>
      <p>Course: <strong>{{course.title}}</strong></p>
    </div>

    <div class="card-section">
      <div class="class-list-info">
        <p><strong>Total Participants:</strong> {{count}}</p>
      </div>

      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Email</th>
            </tr>
          </thead>
          <tbody>
            {{#participants}}
            <tr>
              <td>{{username}}</td>
              <td>{{email}}</td>
            </tr>
            {{/participants}}
            {{^participants}}
            <tr>
              <td colspan="2" class="text-center">No participants yet</td>
            </tr>
            {{/participants}}
          </tbody>
        </table>
      </div>

      <div class="card-action">
        <div class="button-container-full-flex">
          <a href="/admin/courses" class="btn btn-secondary">Back to Courses</a>
        </div>
      </div>
    </div>
  </div>
</main>

{{>footer}}