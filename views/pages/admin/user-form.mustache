{{> head}}
{{> header}}

<main class="wrap">
  <div class="card container">
    <div class="card-header">
      <h1 class="m-0">{{title}}</h1>
    </div>

    {{> errorAlert}}

    <form method="post" action="/admin/users">
      <div class="card-section">
        <h3 class="form-section-title">User Information</h3>

        <div class="field">
          <label for="username" class="form-field-label">Username <span>*</span></label>
          <input id="username" name="username" type="text" required value="{{username}}" class="form-field-input">
        </div>

        <div class="field form-field">
          <label for="email" class="form-field-label">Email <span>*</span></label>
          <input id="email" name="email" type="email" required value="{{email}}" class="form-field-input">
        </div>

        <div class="grid-2-cols m-top-1-5">
          <div>
            <label for="password" class="form-field-label">Password <span>*</span></label>
            <input id="password" name="password" type="password" required class="form-field-input">
          </div>

          <div>
            <label for="passwordConfirm" class="form-field-label">Confirm Password <span>*</span></label>
            <input id="passwordConfirm" name="passwordConfirm" type="password" required class="form-field-input">
          </div>
        </div>
      </div>

      <div class="card-action">
        <div class="button-container-full-flex">
          <button class="btn btn-primary" type="submit">Add User</button>
          <a href="/admin/users" class="btn btn-secondary">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</main>

{{> footer}}
