{{> head}}
{{> header}}

<main class="wrap">
  <div class="card container-sm">
    <div class="card-header">
      <h1 class="m-0">Create Account</h1>
      <p class="page-header-subtitle">Sign up to start booking yoga classes</p>
    </div>

    {{> errorAlert}}

    <form method="post" action="/register">
      <div class="card-section">
        <div class="field">
          <label for="username" class="form-field-label">Username</label>
          <input id="username" name="username" type="text" required value="{{username}}" autofocus class="form-field-input">
        </div>

        <div class="field form-field">
          <label for="email" class="form-field-label">Email</label>
          <input id="email" name="email" type="email" required value="{{email}}" class="form-field-input">
        </div>

        <div class="field form-field">
          <label for="password" class="form-field-label">Password</label>
          <input id="password" name="password" type="password" required minlength="6" class="form-field-input">
          <small class="text-muted">Minimum 6 characters</small>
        </div>

        <div class="field form-field">
          <label for="passwordConfirm" class="form-field-label">Confirm Password</label>
          <input id="passwordConfirm" name="passwordConfirm" type="password" required minlength="6" class="form-field-input">
        </div>
      </div>

      <div class="card-action">
        <button class="btn btn-primary btn-full-width" type="submit">Create Account</button>
      </div>
    </form>

    <div class="card-section section-center-bg">
      <p class="m-0">Already have an account? <a href="/login" class="primary-link">Login here</a></p>
    </div>
  </div>
</main>

{{> footer}}
