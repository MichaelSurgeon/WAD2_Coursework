{{> head}}
{{> header}}

<main class="wrap">
  <div class="container-lg">
    <div class="card m-bottom-2">
      <div class="card-section">
        <h1 class="m-0 m-bottom-1">Welcome to Our Yoga Studio</h1>
        <p class="intro-text">
          We are dedicated to providing high-quality, accessible yoga classes for students of all levels. 
          Our mission is to help you discover the transformative power of yoga through expert instruction, 
          mindful practice, and a supportive community.
        </p>
      </div>
    </div>

    <div class="home-content-grid">
      <div class="card">
        <div class="card-section">
          <h3 class="m-0 m-bottom-1">🧘 Class Levels</h3>
          <ul class="feature-list">
            <li><strong>Beginner</strong> – New to yoga? Start here.</li>
            <li><strong>Intermediate</strong> – Build strength and flexibility.</li>
            <li><strong>Advanced</strong> – Deepen your practice.</li>
          </ul>
        </div>
      </div>

      <div class="card">
        <div class="card-section">
          <h3 class="m-0 m-bottom-1">📅 Class Formats</h3>
          <ul class="feature-list">
            <li><strong>Weekly Blocks</strong> – Multi-week courses.</li>
            <li><strong>Weekend Workshops</strong> – Focused intensive sessions.</li>
            <li><strong>Drop-In Classes</strong> – Come when it suits you.</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="card m-bottom-2">
      <div class="card-section">
        <h2 class="m-0 m-bottom-1">Getting Started</h2>
        {{^user}}
        <p class="getting-started-text">
          Browse our complete course catalog below. Each listing includes location, pricing, class schedule, and availability. 
          <strong><a href="/register" class="primary-link">Register an account</a></strong> to book classes and secure your spot.
        </p>
        {{/user}}
        {{#user}}
        <p class="getting-started-text">
          Browse our course catalog below and book the classes that work for your schedule. 
          You can also view detailed information about each class including location, pricing, and session times.
        </p>
        {{/user}}
      </div>
    </div>

    <h2 class="featured-courses-heading">Featured Courses</h2>
    <section class="cards" aria-label="Featured courses">
      {{#courses}}{{> courseCard}}{{/courses}}
      {{^courses}}<p class="empty-message">No courses available yet.</p>{{/courses}}
    </section>

    <div class="text-center m-top-2">
      <a href="/courses" class="btn btn-primary btn-inline-block">View All Courses</a>
    </div>
  </div>
</main>

{{> footer}}
