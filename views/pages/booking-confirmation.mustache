{{> head}}
{{> header}}

<main class="wrap">
  <div class="card card-narrow">
    <div class="card-header card-header-success">
      <h1>✓ Booking Confirmed</h1>
      <p>Your yoga class booking has been successfully created</p>
    </div>

    <div class="card-section">
      <h3>Booking Details</h3>
      <div class="booking-details-grid">
        <div class="info-box">
          <strong>Booking ID</strong>
          <p class="info-value-mono">{{booking.id}}</p>
        </div>
        <div class="info-box">
          <strong>Type</strong>
          <p class="info-value-capitalize">{{booking.type}}</p>
        </div>
        <div class="info-box">
          <strong>Status</strong>
          <p class="info-value-success-uppercase">{{booking.status}}</p>
        </div>
        <div class="info-box">
          <strong>Created</strong>
          <p class="info-value-muted">{{booking.createdAt}}</p>
        </div>
      </div>
    </div>

    <div class="card-action">
      <a href="/" class="btn btn-primary btn-inline-block">Continue Browsing</a>
    </div>
  </div>
</main>

{{> footer}}
