{{> head}}
{{> header}}

<main class="wrap">
  <div class="card" style="max-width: 600px; margin: 2rem auto;">
    <div class="card-header card-header-success">
      <h1>✓ Booking Confirmed</h1>
      <p>Your yoga class booking has been successfully created</p>
    </div>

    <div class="card-section">
      <h3>Booking Details</h3>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="info-box">
          <strong>Booking ID</strong>
          <p style="margin: 0.5rem 0 0 0; font-family: monospace; color: #666;">{{booking.id}}</p>
        </div>
        <div class="info-box">
          <strong>Type</strong>
          <p style="margin: 0.5rem 0 0 0; color: #666; text-transform: capitalize;">{{booking.type}}</p>
        </div>
        <div class="info-box">
          <strong>Status</strong>
          <p style="margin: 0.5rem 0 0 0; color: #10b981; font-weight: 600; text-transform: uppercase;">{{booking.status}}</p>
        </div>
        <div class="info-box">
          <strong>Created</strong>
          <p style="margin: 0.5rem 0 0 0; color: #666;">{{booking.createdAt}}</p>
        </div>
      </div>
    </div>

    <div class="card-action">
      <a href="/" class="btn btn-primary btn-inline-block">Continue Browsing</a>
    </div>
  </div>
</main>

{{> footer}}
